<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Theme اصلی اپ — رنگ پس‌زمینه Aura برای هماهنگی قبل از لود شدن WebView -->
    <style name="Theme.Aura" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/aura_accent</item>
        <item name="colorPrimaryVariant">@color/aura_accent_alt</item>
        <item name="colorOnPrimary">@color/aura_white</item>
        <item name="colorSecondary">@color/aura_accent_cyan</item>
        <item name="colorOnSecondary">@color/aura_white</item>
        <item name="android:statusBarColor">@color/aura_status_bar</item>
        <item name="android:windowBackground">@drawable/aura_splash</item>
        <item name="android:navigationBarColor">@color/aura_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:fontFamily" tools:ignore="NewApi">sans-serif</item>
    </style>
</resources>
